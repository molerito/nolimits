# Vercel Blob Configuration
# Get your token from: https://vercel.com/docs/storage/vercel-blob/quickstart
# 1. Go to https://vercel.com/docs/storage/vercel-blob
# 2. Click "Create Free KV Store"
# 3. Copy your BLOB_READ_WRITE_TOKEN and paste it below
BLOB_READ_WRITE_TOKEN=your_token_here

# Admin Credentials
# Change these to your desired username and password
# You can also change the password from the admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_password_here
